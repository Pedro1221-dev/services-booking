{
  "buildCommand": "npx prisma generate && npx prisma migrate deploy && npm run build",
  "installCommand": "npm install",
  "framework": null,
  "regions": ["lhr1"],
  "functions": {
    "build/server/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/build/client/assets/$1" },
    { "source": "/(.*)", "destination": "/build/server/index.js" }
  ]
}
