{
  "buildCommand": "npx prisma generate && npm run build",
  "installCommand": "npm install",
  "framework": null,
  "outputDirectory": "build/client",
  "regions": ["lhr1"],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
